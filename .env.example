NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Server-only — never expose in NEXT_PUBLIC_* (get a free key at https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# Demo/admin account — comma-separated emails get curated portfolio + watchlist (read-only)
NEXT_PUBLIC_DEMO_ACCOUNT_EMAIL=demo@marketmate.app

# Server-only — Gemini for AI investing assistant (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
# Optional: gemini-2.0-flash (default), gemini-1.5-flash, etc.
# GEMINI_MODEL=gemini-2.0-flash
